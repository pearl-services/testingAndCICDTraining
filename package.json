    "@angular/forms": "^21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/router": "^21.1.1",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.1.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@vitest/browser-preview": "^4.1.3",
    "@vitest/coverage-v8": "^4.1.3",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
